# Get free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=embedding-001
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_DIMENSIONS=768

# Local Docker: http://localhost:6333 | Dev without Docker: memory | Production: Qdrant Cloud https URL
QDRANT_URL=http://localhost:6333
# Qdrant Cloud API key (optional for local open Qdrant)
QDRANT_API_KEY=
QDRANT_COLLECTION=documents_hybrid
DENSE_VECTOR_WEIGHT=0.7

MAX_CHUNK_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
ADJACENT_CHUNK_COUNT=1
RETRIEVAL_MULTIPLIER=2

RERANKER_URL=http://localhost:8000
RERANKER_ENABLED=false

BM25_STATE_PATH=./data/bm25_df.json

# --- Production-oriented (optional locally) ---
PRODUCTION_MODE=false
DOCS_ENABLED=true
CORS_ORIGINS=
API_KEYS=
